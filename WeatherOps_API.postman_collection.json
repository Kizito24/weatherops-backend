              }
            ],
            "url": {
              "raw": "{{base_url}}/alerts?limit=10&offset=0",
              "host": ["{{base_url}}"],
              "path": ["alerts"],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            }
          }
        },
        {
          "name": "Get Alerts by Location",
