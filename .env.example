# WeatherOps Backend Environment Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control - use .env.local or .env.production

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================
APP_NAME=WeatherOps
APP_VERSION=0.1.0
ENVIRONMENT=development
# Valid values: development, staging, production
DEBUG=False

# ============================================================
# SERVER CONFIGURATION
# ============================================================
HOST=0.0.0.0
PORT=8000
RELOAD=True
# Set RELOAD=False in production

# ============================================================
# SECURITY & JWT
# ============================================================
SECRET_KEY=your-secret-key-change-in-production
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(32))"
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================
# DATABASE - PostgreSQL
# ============================================================
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://weatherops:password@localhost:5432/weatherops
DATABASE_ECHO=False
# Set DATABASE_ECHO=True in development to see SQL queries
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=0
DATABASE_POOL_PRE_PING=True

# ============================================================
# REDIS - Cache & Message Broker
# ============================================================
# Format: redis://[:password]@host:port/db
REDIS_URL=redis://localhost:6379/0
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_SOCKET_KEEPALIVE=True

# ============================================================
# CELERY - Task Queue & Scheduler
# ============================================================
# Leave empty to use REDIS_URL as broker and backend
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_ACCEPT_CONTENT=json
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=UTC
CELERY_TASK_TRACK_STARTED=True
CELERY_TASK_TIME_LIMIT=1800
# Task timeout in seconds (1800 = 30 minutes)

# ============================================================
# EXTERNAL INTEGRATIONS - Weather-AI
# ============================================================
WEATHERAI_BASE_URL=https://api.weather-ai.co
WEATHERAI_API_KEY=your-weatherai-api-key
# Get your API key from: https://weather-ai.co/docs

# ============================================================
# EMAIL NOTIFICATIONS - SendGrid
# ============================================================
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=alerts@weatherops.com
# Get API key from: https://sendgrid.com
# Leave empty to disable email notifications

# ============================================================
# SMS NOTIFICATIONS - Twilio
# ============================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Get credentials from: https://www.twilio.com
# Leave empty to disable SMS notifications

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO
# Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json
# Valid values: json, text
