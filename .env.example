# WeatherOps Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# APPLICATION METADATA
# ============================================================================
APP_NAME=WeatherOps
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=True

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
HOST=0.0.0.0
PORT=8000
RELOAD=True

# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection string
# Format: postgresql+asyncpg://username:password@host:port/database
DATABASE_URL=postgresql+asyncpg://weatherops:password@postgres:5432/weatherops

# Database pool and connection settings
DATABASE_ECHO=False
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_PRE_PING=True

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
# Redis connection string for caching
REDIS_URL=redis://redis:6379/0
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_SOCKET_KEEPALIVE=True

# ============================================================================
# CELERY CONFIGURATION
# ============================================================================
# Celery message broker (uses Redis)
CELERY_BROKER_URL=redis://redis:6379/1

# Celery result backend (uses Redis)
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Task serialization and configuration
CELERY_ACCEPT_CONTENT=json
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=UTC
CELERY_TASK_TRACK_STARTED=True
CELERY_TASK_TIME_LIMIT=3600

# ============================================================================
# EXTERNAL WEATHER API CREDENTIALS
# ============================================================================
# WeatherAI API Configuration
WEATHERAI_API_KEY=your-weatherai-api-key
WEATHERAI_BASE_URL=https://api.weather-ai.co

# ============================================================================
# NOTIFICATION SERVICES
# ============================================================================
# SendGrid Email Service
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@weatherops.com

# Twilio SMS Service
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================================
# DEVELOPMENT & DEBUG
# ============================================================================
VITE_DEBUG=False

# ============================================================================
# CORS CONFIGURATION (Optional)
# ============================================================================
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000
# CORS_ALLOW_CREDENTIALS=True
# CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
# CORS_ALLOW_HEADERS=Content-Type,Authorization

# ============================================================================
# FEATURE FLAGS (Optional)
# ============================================================================
# ENABLE_WEATHER_ALERTS=True
# ENABLE_EMAIL_NOTIFICATIONS=True
# ENABLE_SMS_NOTIFICATIONS=True
# ENABLE_API_DOCS=True

# ============================================================================
# MONITORING & OBSERVABILITY (Optional)
# ============================================================================
# Sentry Error Tracking
# SENTRY_DSN=

# ============================================================================
# NOTES
# ============================================================================
# Required variables for production:
#   - SECRET_KEY: Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
#   - DATABASE_URL: Use a managed PostgreSQL service
#   - WEATHERAI_API_KEY: Register at WeatherAI
#   - SENDGRID_API_KEY: Create account at SendGrid
#   - TWILIO_ACCOUNT_SID & TWILIO_AUTH_TOKEN: Create account at Twilio
#
# For local development with Docker:
#   - Use defaults provided in docker-compose.yml
#   - Override only what you need to change
#
# Loading priority:
#   1. Environment variables
#   2. .env file in project root
#   3. Default values in application code
